# === NewsFlow Environment Variables ===
# Copy this to .env.local and fill in your values

# Convex
CONVEX_DEPLOY_KEY=
VITE_CONVEX_URL=
VITE_CONVEX_SITE_URL=

# Google OAuth
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Cloudflare Turnstile
VITE_CLOUDFLARE_SITE_KEY=
CLOUDFLARE_SECRET_KEY=

# Telegram
TELEGRAM_TOKEN=
TELEGRAM_CHANNEL=

# Facebook
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_TOKEN=

# News APIs
NEWSAPI_KEY=
GNEWS_KEY=
NEWSDATA_KEY=
CURRENTS_KEY=
THENEWSAPI_KEY=

# AI
GEMINI_API_KEY=

# Site URL (your deployed domain)
SITE_URL=https://your-domain.com
